query:
Task 1 — Most Expensive Item per Order


SELECT *
FROM (
    SELECT 
        oi.*,
        (oi.quantity * oi.unit_price) AS item_value,
        ROW_NUMBER() OVER (
            PARTITION BY oi.order_id 
            ORDER BY (oi.quantity * oi.unit_price) DESC
        ) AS rn
    FROM order_items oi
) t
WHERE rn = 1




Task 2 — Top 3 Customers by Spending in Each City


WITH totalspent AS (
    SELECT
        o.customer_id,
        SUM(p.paid_amount) AS total_spending
    FROM payments p 
    JOIN orders o ON p.order_id = o.order_id
    WHERE p.payment_status = 'paid'
    GROUP BY o.customer_id
)

SELECT *
FROM (
    SELECT
        c.*,
        COALESCE(ts.total_spending, 0) AS total_spending,
        ROW_NUMBER() OVER (
            PARTITION BY c.city 
            ORDER BY COALESCE(ts.total_spending, 0) DESC
        ) AS rn
    FROM customers c 
    LEFT JOIN totalspent ts 
        ON ts.customer_id = c.customer_id
) t
WHERE rn <= 3




Task 3 — Latest Order per Customer

SELECT *
FROM (
    SELECT
        o.*,
        ROW_NUMBER() OVER (
            PARTITION BY o.customer_id 
            ORDER BY o.order_date DESC
        ) AS rn
    FROM orders o
) t
WHERE rn = 1;

